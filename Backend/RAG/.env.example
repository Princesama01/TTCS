# Model Configuration
LLAMA_MODEL_PATH=models/llama-3-8b-instruct-q4_K_M.gguf
EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5
RERANK_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2

# Vector Database
FAISS_INDEX_PATH=data/vector_store/faiss_index
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# Retrieval Configuration
TOP_K_RETRIEVAL=10
TOP_K_RERANK=3
SIMILARITY_THRESHOLD=0.7

# LLM Configuration
N_GPU_LAYERS=0  # Set to -1 for full GPU offload
N_CTX=4096
TEMPERATURE=0.1
MAX_TOKENS=512

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
ENABLE_CORS=true

# Performance
N_BATCH=512
N_THREADS=4

# Data Paths
PDF_DATA_DIR=data/documents
PROCESSED_DATA_DIR=data/processed
LOGS_DIR=logs
